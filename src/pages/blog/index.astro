---
import Layout from "../../layouts/Layout.astro";
import Title from "../../components/core/TitleScreen.astro";
import { getCollection } from "astro:content";
import BlogCard from "../../components/core/BlogCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);
---

<Layout>
  <Title title="Blog" subtitle="My personal bullshit outlet" />
  <div class="pb-20 grid grid-cols-1 md:grid-cols-2 gap-5 w-full max-w-5xl p-5">
    {
      posts.map(({ data: { title, date, summary }, slug }) => (
        <BlogCard title={title} date={date} summary={summary} slug={slug} />
      ))
    }
  </div>
</Layout>
