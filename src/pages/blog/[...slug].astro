---
import type { GetStaticPaths } from "astro";
import { getCollection} from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Title from "../../components/core/TitleScreen.astro";
import type { CollectionEntry } from "astro:content";
import BlogTitle from "../../components/core/BlogTitle.astro";
import mdxComponents from "../../data/mdx-components";

export const prerender = true;

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}) satisfies GetStaticPaths;

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout>
  <div>
    <BlogTitle title={post.data.title} date={post.data.date} />
  </div>
  <div class="flex flex-col items-center w-full pb-20">
    <div class="flex flex-col items-center max-w-4xl gap-5 p-5">
      <Content components={mdxComponents} />
    </div>
  </div>
</Layout>
