---
import {navEntries} from "./nav-entries";
import {Icon} from "astro-icon/components";

const entries = navEntries;
---

<div class="md:hidden z-40 fixed flex justify-evenly items-center bottom-0 left-0 drop-shadow-2xl bg-base-200 w-full">
  {entries.map(({name, icon, url}) => (
    <a href={url} aria-label={name} class="p-4">
      <Icon name={icon} />
    </a>
  ))}
</div>